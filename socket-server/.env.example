# Port — Render sets this automatically. Default 3001 for local dev.
PORT=3001

# Comma-separated list of allowed CORS origins for the Socket.IO handshake.
# Include the Vercel URL, the Capacitor app URL, and any preview domains.
ALLOWED_ORIGINS=https://naql-go.vercel.app,https://naqlgo.vercel.app,capacitor://localhost,https://localhost,http://localhost:3000

# Same secret as the Next.js app — used to verify JWTs minted by /api/socket-token.
SOCKET_JWT_SECRET=

# Upstash Redis TLS connection string (for pub/sub).
# Format: rediss://default:<TOKEN>@<endpoint>:6379
# Find this in Upstash Console → your DB → "Connect" → Node.js (or any TLS section).
REDIS_URL=

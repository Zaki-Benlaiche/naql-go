generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?  @unique
  password  String
  role      String   // CLIENT | TRANSPORTER | ADMIN
  isOnline     Boolean  @default(false)
  isActive     Boolean  @default(true)
  avgRating    Float?
  totalRatings Int      @default(0)
  wilaya       String?
  vehicleType  String?
  vehicleColor String?
  // Services this transporter offers (a driver can be more than one).
  isLivreur      Boolean @default(false)
  isFrodeur      Boolean @default(false)
  isTransporteur Boolean @default(true)
  createdAt    DateTime @default(now())

  requests        TransportRequest[] @relation("ClientRequests")
  directRequests  TransportRequest[] @relation("DirectRequests")
  bids            Bid[]
  vehicles        Vehicle[]
  notifications   Notification[]
  ratingsGiven    Rating[]           @relation("RatingClient")
  ratingsReceived Rating[]           @relation("RatingTransporter")
  couponUses      CouponUse[]
  documents       Document[]

  @@map("users")
}

model Vehicle {
  id            String   @id @default(cuid())
  type          String
  model         String
  plate         String   @unique
  capacity      Float
  transporterId String
  transporter   User     @relation(fields: [transporterId], references: [id])
  createdAt     DateTime @default(now())

  @@map("vehicles")
}

model TransportRequest {
  id            String   @id @default(cuid())
  clientId      String
  client        User     @relation("ClientRequests", fields: [clientId], references: [id])

  fromCity      String
  toCity        String
  fromAddress   String
  toAddress     String

  goodsType     String?
  vehicleType   String   @default("any")
  size          String   @default("medium")
  weight        Float?
  description   String?
  // LIVREUR | FRODEUR | TRANSPORTEUR
  serviceCategory String @default("TRANSPORTEUR")
  estimatedPrice Float?
  scheduledAt   DateTime?

  status           String   @default("OPEN")
  proofOfDelivery  String?

  discountPercent  Int?
  finalPrice       Float?
  transportType    String   @default("INTER")
  assignedTransporterId String?
  assignedTransporter   User?   @relation("DirectRequests", fields: [assignedTransporterId], references: [id])

  bids          Bid[]
  acceptedBidId String?  @unique
  acceptedBid   Bid?     @relation("AcceptedBid", fields: [acceptedBidId], references: [id])
  rating        Rating?
  messages      Message[]
  locationTrack LocationTrack?

  fromLat Float?
  fromLng Float?
  toLat   Float?
  toLng   Float?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("transport_requests")
}

model Bid {
  id            String   @id @default(cuid())
  requestId     String
  request       TransportRequest @relation(fields: [requestId], references: [id])
  transporterId String
  transporter   User     @relation(fields: [transporterId], references: [id])

  price         Float
  estimatedTime String
  note          String?
  status        String   @default("PENDING")

  acceptedRequest TransportRequest? @relation("AcceptedBid")

  createdAt     DateTime @default(now())

  @@unique([requestId, transporterId])
  @@map("bids")
}

model Rating {
  id            String   @id @default(cuid())
  requestId     String   @unique
  request       TransportRequest @relation(fields: [requestId], references: [id])
  clientId      String
  client        User     @relation("RatingClient", fields: [clientId], references: [id])
  transporterId String
  transporter   User     @relation("RatingTransporter", fields: [transporterId], references: [id])
  score         Int
  comment       String?
  createdAt     DateTime @default(now())

  @@map("ratings")
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Int
  maxUses         Int      @default(100)
  usedCount       Int      @default(0)
  expiresAt       DateTime?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  uses CouponUse[]

  @@map("coupons")
}

model CouponUse {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  requestId String?
  createdAt DateTime @default(now())

  @@unique([couponId, userId])
  @@map("coupon_uses")
}

model Message {
  id         String   @id @default(cuid())
  requestId  String
  request    TransportRequest @relation(fields: [requestId], references: [id])
  senderId   String
  senderName String
  senderRole String   // CLIENT | TRANSPORTER
  text       String
  createdAt  DateTime @default(now())

  @@map("messages")
}

model LocationTrack {
  requestId String   @id
  request   TransportRequest @relation(fields: [requestId], references: [id])
  lat       Float
  lng       Float
  updatedAt DateTime @updatedAt

  @@map("location_tracks")
}

model Document {
  id            String   @id @default(cuid())
  transporterId String
  transporter   User     @relation(fields: [transporterId], references: [id])
  type          String   // license | vehicle_reg | insurance | other
  fileData      String   // base64
  status        String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt     DateTime @default(now())

  @@map("documents")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  type      String
  read      Boolean  @default(false)
  requestId String?
  createdAt DateTime @default(now())

  @@map("notifications")
}
